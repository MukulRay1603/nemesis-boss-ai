# ============================================================
# Nemesis Boss AI — .gitignore
# ============================================================

# ------------------------------------------------------------
# Unity — generated folders, never commit
# ------------------------------------------------------------
Unity Project/Library/
Unity Project/Temp/
Unity Project/obj/
Unity Project/Build/
Unity Project/Builds/
Unity Project/Logs/
Unity Project/UserSettings/
Unity Project/.vs/
Unity Project/sysinfo.txt
Unity Project/mono_crash.*

# Unity file types
Unity Project/*.sln
Unity Project/*.csproj
Unity Project/*.suo
Unity Project/*.user
Unity Project/*.log
Unity Project/*.apk
Unity Project/*.aab
Unity Project/*.unitypackage
Unity Project/*.unitypackage.meta

# TextMesh Pro package examples (imported via Package Manager, not project code)
Unity Project/Assets/TextMesh Pro/
Unity Project/Assets/TextMesh Pro.meta

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
nemesis-env/
rllib-env/
venv/
.venv/

# ------------------------------------------------------------
# Secrets — never commit
# ------------------------------------------------------------
.env
*.env

# ------------------------------------------------------------
# MLflow local experiment store
# ------------------------------------------------------------
mlruns/
mlartifacts/

# ------------------------------------------------------------
# OS / editor
# ------------------------------------------------------------
.DS_Store
Thumbs.db
*.log
.vscode/
